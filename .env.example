# CareSync API - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# PostgreSQL connection string (Neon.tech recommended for free tier)
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@localhost/caresync

# JWT secret key - must be at least 32 characters
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key-here

# API environment: development | production
ENVIRONMENT=development

# Enable verbose SQL logs (development only)
DEBUG=false

# APScheduler background jobs (set to false on serverless platforms like Vercel)
ENABLE_SCHEDULER=true

# Gmail SMTP for missed-dose alerts (optional)
# Requires a Gmail App Password, NOT your account password
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here
